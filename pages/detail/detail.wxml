<!-- 产品详情页 -->
<view class="page" wx:if="{{product}}">

  <!-- 产品大图 -->
  <view class="hero-img-wrap" bindtap="onPreviewImage">
    <image class="hero-img"
      src="{{product.image}}"
      mode="aspectFill"
      binderror="onImgError"
    />
    <view class="img-overlay">
      <text class="img-hint">点击查看大图</text>
    </view>
  </view>

  <!-- 产品基本信息卡 -->
  <view class="info-card">
    <view class="info-top">
      <view class="info-left">
        <text class="info-category">{{product.category}}</text>
        <text class="info-name">{{product.name}}</text>
        <text class="info-origin">📍 {{product.origin}}</text>
      </view>
      <view class="info-right">
        <text class="price-symbol">¥</text>
        <text class="price-value">{{product.price}}</text>
        <text class="price-unit">/{{product.unit}}</text>
      </view>
    </view>

    <!-- 标签 -->
    <view class="info-tags">
      <text class="info-tag" wx:for="{{product.tags}}" wx:key="*this">
        {{item}}
      </text>
    </view>
  </view>

  <!-- 产地插画地图 -->
  <view class="section">
    <view class="section-title">产地溯源</view>
    <origin-map
      origin="{{product.origin}}"
      coord="{{product.originCoord}}"
      product-name="{{product.name}}"
    />
    <text class="origin-note">* 插画示意产品产地位置</text>
  </view>

  <!-- 产品介绍 -->
  <view class="section">
    <view class="section-title">产品介绍</view>
    <text class="desc-text">{{product.description}}</text>
  </view>

  <!-- 背后故事 -->
  <view class="section">
    <view class="section-title">产地故事</view>
    <view class="story-card">
      <view class="story-quote">"</view>
      <text class="story-text">{{product.story}}</text>
    </view>
  </view>

  <!-- 相关推荐 -->
  <view class="section" wx:if="{{relatedProducts.length > 0}}">
    <view class="section-title">相关推荐</view>
    <scroll-view class="related-scroll" scroll-x="{{true}}">
      <view class="related-item"
        wx:for="{{relatedProducts}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="onTapRelated">
        <image class="related-img"
          src="{{item.image}}"
          mode="aspectFill"
          lazy-load="{{true}}"
          binderror="onImgError"
        />
        <text class="related-name">{{item.name}}</text>
        <view class="related-price">
          <text class="price-symbol">¥</text>
          <text class="price-value small">{{item.price}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 底部留白 -->
  <view class="bottom-space"></view>
</view>
