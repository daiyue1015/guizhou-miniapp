/* 详情页样式 */

.page {
  background: #F5F0E8;
  min-height: 100vh;
}

/* ======== 产品大图 ======== */
.hero-img-wrap {
  position: relative;
  width: 100%;
  height: 500rpx;
  background: linear-gradient(160deg, #E8EFE2 0%, #D5DCC5 30%, #CAD2B8 60%, #DEE2D0 100%);
}

.hero-img {
  width: 100%;
  height: 100%;
  position: relative;
  z-index: 1;
}

.img-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 0;
  background: linear-gradient(transparent, rgba(0,0,0,0.3));
  text-align: center;
}

.img-hint {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
}

/* ======== 基本信息卡 ======== */
.info-card {
  margin: -40rpx 32rpx 0;
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  position: relative;
  z-index: 2;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.04);
}

.info-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.info-left {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.info-category {
  font-size: 22rpx;
  color: #C4923A;
  background: #FAF6ED;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  align-self: flex-start;
  margin-bottom: 12rpx;
}

.info-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #2C2420;
  line-height: 1.2;
}

.info-origin {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #888;
}

.info-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
}

.info-tags {
  display: flex;
  gap: 12rpx;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #F0EDE4;
}

.info-tag {
  padding: 6rpx 20rpx;
  font-size: 22rpx;
  color: #8B6914;
  background: #FAF6ED;
  border-radius: 16rpx;
  border: 1rpx solid #E8DCC8;
}

/* ======== 通用分组 ======== */
.section {
  margin: 40rpx 32rpx 0;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2C2420;
  padding-left: 20rpx;
  margin-bottom: 20rpx;
  position: relative;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 6rpx;
  bottom: 6rpx;
  width: 6rpx;
  background: #C4923A;
  border-radius: 3rpx;
}

/* ======== 产地标注 ======== */
.origin-note {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #bbb;
  text-align: center;
}

/* ======== 产品介绍 ======== */
.desc-text {
  font-size: 28rpx;
  color: #4a4a4a;
  line-height: 1.8;
}

/* ======== 产地故事卡片 ======== */
.story-card {
  position: relative;
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
}

.story-quote {
  position: absolute;
  top: 16rpx;
  left: 24rpx;
  font-size: 80rpx;
  color: #E8DCC8;
  font-family: Georgia, serif;
  line-height: 1;
}

.story-text {
  font-size: 28rpx;
  color: #5a5a5a;
  line-height: 1.8;
  position: relative;
  z-index: 1;
}

/* ======== 价格统一样式 ======== */
.price-symbol {
  font-size: 26rpx;
  color: #C4923A;
  font-weight: 600;
}

.price-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #C4923A;
  line-height: 1;
}

.price-value.small {
  font-size: 32rpx;
}

.price-unit {
  font-size: 24rpx;
  color: #aaa;
}

/* ======== 相关推荐横向滚动 ======== */
.related-scroll {
  display: flex;
  white-space: nowrap;
}

.related-item {
  display: inline-flex;
  flex-direction: column;
  width: 200rpx;
  margin-right: 16rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.related-item:active {
  opacity: 0.85;
}

.related-img {
  width: 200rpx;
  height: 200rpx;
  background: linear-gradient(135deg, #E8EFE2, #D8DFCB);
  position: relative;
  z-index: 1;
}

.related-name {
  padding: 12rpx 16rpx 4rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #2C2420;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.related-price {
  padding: 0 16rpx 16rpx;
  display: flex;
  align-items: baseline;
}

/* ======== 底部留白 ======== */
.bottom-space {
  height: 60rpx;
}
